# ============================================================
# MokuTomo 環境変数
# 値は絶対にリポジトリへコミットしないでください。
# ローカル開発では `.env.local` にコピーして値を設定します。
# ============================================================

# --- Supabase (必須) ---
# `supabase start` 実行時に表示されるローカル値、または Supabase ダッシュボードの値
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サーバー専用。クライアントへ絶対に公開しないこと
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- アプリ ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MokuTomo

# --- WebRTC ---
# STUNのみでも動作するが、本番はTURNサーバーの設定を強く推奨
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302
# 例: turn:turn.example.com:3478 (未設定なら使用しない)
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# --- Stripe (有料プラン / テストモードのキーを使用) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Stripeダッシュボードで作成した価格ID (月額プラン)
STRIPE_PRICE_ID_PREMIUM=price_xxx

# --- メール (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=MokuTomo <noreply@example.com>

# --- 監視 (任意) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
