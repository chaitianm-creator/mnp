# ============================================================
# AI CREATIVE OFFICE 環境変数
# APIキーは絶対にGitへコミットしないでください(.env.localに設定)
# 未設定の場合、アプリはモックモード(デモ生成)で動作します
# ============================================================

# AIプロバイダー: mock | anthropic (openai / gemini は将来対応)
AI_PROVIDER=mock

# Anthropic Claude(AI_PROVIDER=anthropic のとき必須)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# 1タスクあたりの最大出力トークン数(既定: 4000、上限: 8000)
AI_MAX_TOKENS_PER_TASK=4000

# 1回の実行(依頼)あたりのAI利用料上限(円)。超過時は停止して承認を求める
AI_MAX_COST_JPY=500
